<% content_for :title, "Dashboard" %>

<h2 class="mb-4">Dashboard</h2>

<%# Stats row %>
<div class="row g-3 mb-5">
  <div class="col-sm-6 col-lg-3">
    <div class="card text-center h-100">
      <div class="card-body">
        <div class="fs-1 fw-bold"><%= @total_members %></div>
        <div class="text-muted">Total Members</div>
      </div>
      <div class="card-footer">
        <%= link_to "View all", users_path, class: "text-decoration-none small" %>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-lg-3">
    <div class="card text-center h-100 border-success">
      <div class="card-body">
        <div class="fs-1 fw-bold text-success"><%= @active_members %></div>
        <div class="text-muted">Active</div>
      </div>
      <div class="card-footer">
        <%= link_to "View active", users_path(sort: "active", direction: "desc"), class: "text-decoration-none small" %>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-lg-3">
    <div class="card text-center h-100 border-secondary">
      <div class="card-body">
        <div class="fs-1 fw-bold text-secondary"><%= @inactive_members %></div>
        <div class="text-muted">Inactive</div>
      </div>
      <div class="card-footer">
        <%= link_to "View inactive", users_path(sort: "active", direction: "asc"), class: "text-decoration-none small" %>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-lg-3">
    <div class="card text-center h-100 <%= @pending_sync > 0 ? 'border-warning' : 'border-success' %>">
      <div class="card-body">
        <div class="fs-1 fw-bold <%= @pending_sync > 0 ? 'text-warning' : 'text-success' %>"><%= @pending_sync %></div>
        <div class="text-muted">Pending Sync</div>
      </div>
      <div class="card-footer">
        <%= link_to "View pending", users_path(sort: "synced", direction: "asc"), class: "text-decoration-none small" %>
      </div>
    </div>
  </div>
</div>

<%# Sync panel %>
<div class="card mb-4 <%= @pending_sync > 0 ? 'border-warning' : 'border-secondary' %>">
  <div class="card-body d-flex align-items-center justify-content-between gap-3">
    <div>
      <span class="fw-semibold">Controller Sync</span>
      <% if @pending_sync > 0 %>
        <span class="badge bg-warning text-dark ms-2"><%= @pending_sync %> pending</span>
        <span class="text-muted ms-1">member(s) have changes not yet sent to the controller.</span>
      <% else %>
        <span class="text-muted ms-2">All members are in sync with the controller.</span>
      <% end %>
    </div>
    <%= button_to "Sync Now", sync_users_path,
          class: "btn #{@pending_sync > 0 ? 'btn-warning' : 'btn-outline-secondary'} flex-shrink-0",
          form: { onsubmit: @pending_sync > 0 ? "return confirm('Push #{@pending_sync} pending change(s) to the controller?')" : nil } %>
  </div>
</div>

<%# Lockdown panel %>
<div class="card mb-5 <%= @lockdown_active ? 'border-danger' : 'border-secondary' %>">
  <div class="card-body d-flex align-items-center justify-content-between gap-3">
    <div>
      <% if @lockdown_active %>
        <span class="badge bg-danger fs-6 me-2">LOCKDOWN ACTIVE</span>
        <span class="text-muted">Standard members (<%= @standard_count %>) have been removed from the controller. Officers (<%= @officer_count %>) still have access.</span>
      <% else %>
        <span class="fw-semibold">Access Control</span>
        <span class="text-muted ms-2"><%= @officer_count %> officer(s) · <%= @standard_count %> standard member(s)</span>
      <% end %>
    </div>
    <div class="d-flex gap-2 flex-shrink-0">
      <% if @lockdown_active %>
        <%= button_to "Restore Access", restore_path,
              class: "btn btn-success",
              form: { onsubmit: "return confirm('Re-add all standard members to the controller?')" } %>
      <% else %>
        <%= button_to "Lockdown", lockdown_path,
              class: "btn btn-danger",
              form: { onsubmit: "return confirm('Remove all standard members from the controller? Officers will keep access.')" } %>
      <% end %>
    </div>
  </div>
</div>

<%# Danger zone %>
<div class="card mb-5 border-danger">
  <div class="card-header bg-danger text-white fw-semibold d-flex justify-content-between align-items-center"
       style="cursor:pointer" data-bs-toggle="collapse" data-bs-target="#danger-zone" aria-expanded="false" aria-controls="danger-zone">
    Danger Zone
    <span class="small opacity-75">click to expand</span>
  </div>
  <div id="danger-zone" class="collapse">
  <div class="card-body d-flex align-items-center justify-content-between gap-3">
    <div>
      <div class="fw-semibold">Clear All Users from Controller</div>
      <div class="text-muted small">Removes every member slot the app knows about from the controller hardware. All members will be marked unsynced.</div>
    </div>
    <%= button_to "Clear Controller", clear_users_path,
          class: "btn btn-danger flex-shrink-0",
          form: { onsubmit: "return confirm('Remove ALL #{@total_members} member(s) from the controller? Everyone will lose access until re-synced. This cannot be undone.')" } %>
  </div>
  <div class="card-body border-top d-flex align-items-center justify-content-between gap-3">
    <div>
      <div class="fw-semibold">Force Clear Controller</div>
      <div class="text-muted small">Walks all 1998 slots (3–2000) and deletes each one from the hardware, regardless of what the app knows. Use when the controller has users the app doesn't know about (e.g. after Hub Manager).</div>
    </div>
    <%= button_to "Force Clear", force_clear_users_path,
          class: "btn btn-danger flex-shrink-0",
          form: { onsubmit: "return confirm('Walk all 1998 slots and remove every user from the controller hardware? This cannot be undone.')" } %>
  </div>
  </div>
</div>

<%# Recent events %>
<div class="d-flex justify-content-between align-items-center mb-2">
  <h5 class="mb-0">Recent Events</h5>
  <%= link_to "View all", access_events_path, class: "small" %>
</div>

<% if @recent_events.any? %>
  <table class="table table-hover align-middle">
    <thead class="table-dark">
      <tr>
        <th>Time</th>
        <th>Member</th>
        <th>Event</th>
      </tr>
    </thead>
    <tbody>
      <% @recent_events.each do |event| %>
        <tr>
          <td class="text-nowrap text-muted small">
            <%= event.occurred_at.strftime("%-m/%-d/%Y %-I:%M %p") %>
          </td>
          <td>
            <% if event.user %>
              <%= link_to event.user.full_name, user_path(event.user) %>
            <% else %>
              <span class="text-muted">Unknown</span>
            <% end %>
          </td>
          <td><%= event_type_badge(event) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="text-muted">No events recorded yet.</p>
<% end %>
