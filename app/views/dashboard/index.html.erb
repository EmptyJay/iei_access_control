<% content_for :title, "Dashboard" %>

<h2 class="mb-4">Dashboard</h2>

<%# Stats row %>
<div class="row g-3 mb-5">
  <div class="col-sm-6 col-lg-3">
    <div class="card text-center h-100">
      <div class="card-body">
        <div class="fs-1 fw-bold"><%= @total_members %></div>
        <div class="text-muted">Total Members</div>
      </div>
      <div class="card-footer">
        <%= link_to "View all", users_path, class: "text-decoration-none small" %>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-lg-3">
    <div class="card text-center h-100 border-success">
      <div class="card-body">
        <div class="fs-1 fw-bold text-success"><%= @active_members %></div>
        <div class="text-muted">Active</div>
      </div>
      <div class="card-footer">
        <%= link_to "View active", users_path(sort: "active", direction: "desc"), class: "text-decoration-none small" %>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-lg-3">
    <div class="card text-center h-100 border-secondary">
      <div class="card-body">
        <div class="fs-1 fw-bold text-secondary"><%= @inactive_members %></div>
        <div class="text-muted">Inactive</div>
      </div>
      <div class="card-footer">
        <%= link_to "View inactive", users_path(sort: "active", direction: "asc"), class: "text-decoration-none small" %>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-lg-3">
    <div class="card text-center h-100 <%= @pending_sync > 0 ? 'border-warning' : 'border-success' %>">
      <div class="card-body">
        <div class="fs-1 fw-bold <%= @pending_sync > 0 ? 'text-warning' : 'text-success' %>"><%= @pending_sync %></div>
        <div class="text-muted">Pending Sync</div>
      </div>
      <div class="card-footer">
        <%= link_to "View pending", users_path(sort: "synced", direction: "asc"), class: "text-decoration-none small" %>
      </div>
    </div>
  </div>
</div>

<%# Recent events %>
<div class="d-flex justify-content-between align-items-center mb-2">
  <h5 class="mb-0">Recent Events</h5>
  <%= link_to "View all", access_events_path, class: "small" %>
</div>

<% if @recent_events.any? %>
  <table class="table table-hover align-middle">
    <thead class="table-dark">
      <tr>
        <th>Time</th>
        <th>Member</th>
        <th>Event</th>
      </tr>
    </thead>
    <tbody>
      <% @recent_events.each do |event| %>
        <tr>
          <td class="text-nowrap text-muted small">
            <%= event.occurred_at.strftime("%-m/%-d/%Y %-I:%M %p") %>
          </td>
          <td>
            <% if event.user %>
              <%= link_to event.user.full_name, edit_user_path(event.user) %>
            <% else %>
              <span class="text-muted">Unknown</span>
            <% end %>
          </td>
          <td><%= event_type_badge(event) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="text-muted">No events recorded yet.</p>
<% end %>
