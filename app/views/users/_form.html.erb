<%= form_with model: user do |f| %>
  <% if user.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% user.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row">
    <div class="col-md-6 mb-3">
      <%= f.label :first_name, class: "form-label" %>
      <%= f.text_field :first_name, class: "form-control", autofocus: true,
            autocomplete: "off", data: { "1p-ignore": true } %>
    </div>
    <div class="col-md-6 mb-3">
      <%= f.label :last_name, class: "form-label" %>
      <%= f.text_field :last_name, class: "form-control",
            autocomplete: "off", data: { "1p-ignore": true } %>
    </div>
  </div>

  <div class="row">
    <div class="col-md-4 mb-3">
      <%= f.label :card_number, "Badge #", class: "form-label" %>
      <%= f.number_field :card_number, class: "form-control", min: 1,
            autocomplete: "off", data: { "1p-ignore": true } %>
    </div>
  </div>

  <div class="row">
    <div class="col-md-4 mb-3">
      <%= f.label :slot, class: "form-label" %>
      <div class="input-group">
        <%= f.number_field :slot, class: "form-control", min: 1,
              readonly: true, tabindex: -1, style: "pointer-events:none",
              id: "slot_field" %>
        <button type="button" class="btn btn-outline-secondary" id="slot_unlock"
                tabindex="-1" title="Unlock to edit"
                onclick="
                  var field = document.getElementById('slot_field');
                  var locked = field.hasAttribute('readonly');
                  if (locked) {
                    field.removeAttribute('readonly');
                    field.tabIndex = 0;
                    field.style.pointerEvents = '';
                    this.textContent = '\uD83D\uDD13';
                    this.title = 'Lock';
                    field.focus();
                  } else {
                    field.setAttribute('readonly', true);
                    field.tabIndex = -1;
                    field.style.pointerEvents = 'none';
                    this.textContent = '\uD83D\uDD12';
                    this.title = 'Unlock to edit';
                  }
                ">
          &#x1F512;
        </button>
      </div>
      <div class="form-text">Controller memory slot (auto-assigned)</div>
    </div>
    <div class="col-md-4 mb-3">
      <%= f.label :site_code, class: "form-label" %>
      <div class="input-group">
        <%= f.number_field :site_code, class: "form-control", min: 0,
              readonly: true, tabindex: -1, style: "pointer-events:none",
              id: "site_code_field" %>
        <button type="button" class="btn btn-outline-secondary" id="site_code_unlock"
                tabindex="-1" title="Unlock to edit"
                onclick="
                  var field = document.getElementById('site_code_field');
                  var locked = field.hasAttribute('readonly');
                  if (locked) {
                    field.removeAttribute('readonly');
                    field.tabIndex = 0;
                    field.style.pointerEvents = '';
                    this.textContent = '\uD83D\uDD13';
                    this.title = 'Lock';
                    field.focus();
                  } else {
                    field.setAttribute('readonly', true);
                    field.tabIndex = -1;
                    field.style.pointerEvents = 'none';
                    this.textContent = '\uD83D\uDD12';
                    this.title = 'Unlock to edit';
                  }
                ">
          &#x1F512;
        </button>
      </div>
    </div>
  </div>

  <div class="row mb-4">
    <div class="col-md-4">
      <%= f.label :tier, class: "form-label" %>
      <%= f.select :tier, User::TIERS.map { |t| [t.capitalize, t] }, {}, class: "form-select" %>
      <div class="form-text">Officers keep access during lockdown.</div>
    </div>
  </div>

  <div class="mb-4">
    <div class="form-check form-switch">
      <%= f.check_box :active, class: "form-check-input", role: "switch" %>
      <%= f.label :active, "Active (can access door)", class: "form-check-label" %>
    </div>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", users_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
