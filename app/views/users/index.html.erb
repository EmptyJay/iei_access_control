<% content_for :title, "Members" %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h2 class="mb-0">Members <span class="badge bg-secondary fs-6" id="visible-count"><%= @users.size %></span></h2>
  <div class="d-flex gap-2">
    <%= link_to "Export CSV", export_users_path, class: "btn btn-outline-secondary" %>
    <%= link_to "Import CSV", import_users_path, class: "btn btn-outline-primary" %>
    <%= link_to "Add Member", new_user_path, class: "btn btn-primary" %>
  </div>
</div>

<% if @users.any? %>
  <%# Filter bar %>
  <div class="row g-2 align-items-center mb-3">
    <div class="col-sm-4">
      <input type="search" id="name-search" class="form-control" placeholder="Search by name…"
             oninput="onFilterChange()" autocomplete="off" data-1p-ignore>
    </div>
    <div class="col-auto">
      <div class="btn-group" role="group" aria-label="Status filter">
        <input type="radio" class="btn-check" name="status-filter" id="status-all"      value=""      checked onchange="onFilterChange()">
        <label class="btn btn-outline-secondary btn-sm" for="status-all">All</label>
        <input type="radio" class="btn-check" name="status-filter" id="status-active"   value="true"         onchange="onFilterChange()">
        <label class="btn btn-outline-success btn-sm"   for="status-active">Active</label>
        <input type="radio" class="btn-check" name="status-filter" id="status-inactive" value="false"        onchange="onFilterChange()">
        <label class="btn btn-outline-secondary btn-sm" for="status-inactive">Inactive</label>
      </div>
    </div>
    <div class="col-auto">
      <div class="btn-group" role="group" aria-label="Sync filter">
        <input type="radio" class="btn-check" name="sync-filter" id="sync-all"     value=""      checked onchange="onFilterChange()">
        <label class="btn btn-outline-secondary btn-sm" for="sync-all">All</label>
        <input type="radio" class="btn-check" name="sync-filter" id="sync-synced"  value="true"         onchange="onFilterChange()">
        <label class="btn btn-outline-success btn-sm"   for="sync-synced">Synced</label>
        <input type="radio" class="btn-check" name="sync-filter" id="sync-pending" value="false"        onchange="onFilterChange()">
        <label class="btn btn-outline-warning btn-sm"   for="sync-pending">Pending</label>
      </div>
    </div>
    <div class="col-auto">
      <select id="page-size" class="form-select form-select-sm" style="width:auto" onchange="onPageSizeChange()">
        <option value="25" selected>25 / page</option>
        <option value="50">50 / page</option>
        <option value="100">100 / page</option>
        <option value="0">All</option>
      </select>
    </div>
    <div class="col-auto">
      <button class="btn btn-sm btn-link text-muted" onclick="clearFilters()">Clear</button>
    </div>
  </div>

  <%# Bulk form wraps only the action bar — table is outside to avoid nested forms %>
  <%= form_tag bulk_update_users_path, id: "bulk-form" do %>
    <div id="bulk-bar" class="d-none align-items-center gap-2 mb-3 p-2 bg-light border rounded">
      <span class="text-muted small me-1"><span id="bulk-count">0</span> selected</span>
      <button type="submit" name="bulk_action" value="activate"      class="btn btn-sm btn-success">Activate</button>
      <button type="submit" name="bulk_action" value="deactivate"    class="btn btn-sm btn-secondary">Deactivate</button>
      <button type="submit" name="bulk_action" value="mark_unsynced" class="btn btn-sm btn-warning text-dark">Mark Unsynced</button>
      <button type="submit" name="bulk_action" value="delete"
              class="btn btn-sm btn-danger ms-2"
              onclick="return confirm('Permanently delete ' + document.getElementById('bulk-count').textContent + ' member(s)? This cannot be undone.')">
        Delete
      </button>
      <button type="button" class="btn btn-sm btn-link text-muted ms-auto" onclick="clearSelection()">Clear</button>
    </div>
  <% end %>

  <table class="table table-hover align-middle">
    <thead class="table-dark">
      <tr>
        <th style="width:1%">
          <input type="checkbox" id="select-all" class="form-check-input"
                 title="Select all" onclick="toggleAll(this)">
        </th>
        <th><%= sort_link("First Name", "first_name") %></th>
        <th><%= sort_link("Last Name", "last_name") %></th>
        <th>Slot</th>
        <th><%= sort_link("Badge #", "card_number") %></th>
        <th><%= sort_link("Status", "active") %></th>
        <th><%= sort_link("Synced", "synced") %></th>
        <th></th>
      </tr>
    </thead>
    <tbody id="members-tbody">
      <% @users.each do |user| %>
        <tr style="cursor:pointer"
            data-name="<%= "#{user.first_name} #{user.last_name}".downcase %>"
            data-active="<%= user.active %>"
            data-synced="<%= user.synced %>"
            onclick="window.location='<%= user_path(user) %>'">
          <td onclick="event.stopPropagation()">
            <input type="checkbox" data-user-id="<%= user.id %>"
                   class="form-check-input row-checkbox" onchange="updateBulkBar()">
          </td>
          <td><%= user.first_name %></td>
          <td><%= user.last_name %></td>
          <td class="text-muted"><%= user.slot %></td>
          <td><code><%= user.card_number %></code></td>
          <td>
            <% if user.active? %>
              <span class="badge bg-success">Active</span>
            <% else %>
              <span class="badge bg-secondary">Inactive</span>
            <% end %>
          </td>
          <td>
            <% if user.synced? %>
              <span class="badge bg-success">Synced</span>
            <% else %>
              <span class="badge bg-warning text-dark">Pending</span>
            <% end %>
          </td>
          <td class="text-end">
            <div class="d-flex justify-content-end gap-1" onclick="event.stopPropagation()">
              <%= link_to edit_user_path(user),
                    class: "btn btn-sm btn-outline-secondary",
                    title: "Edit #{user.full_name}" do %>
                <i class="bi bi-pencil"></i>
              <% end %>
              <%= button_to user_path(user), method: :delete,
                    class: "btn btn-sm btn-outline-danger",
                    form: { onsubmit: "return confirm('Remove #{user.full_name}?')" },
                    title: "Remove #{user.full_name}" do %>
                <i class="bi bi-trash"></i>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div class="d-flex justify-content-between align-items-center mt-2">
    <p id="no-results" class="text-muted mb-0 d-none">No members match the current filters.</p>
    <p id="page-info" class="text-muted small mb-0"></p>
    <nav id="pagination"></nav>
  </div>

<% else %>
  <p class="text-muted">No members yet. <%= link_to "Add one", new_user_path %>.</p>
<% end %>

<script>
  let currentPage = 1;
  let pageSize    = 25;

  function allRows() {
    return Array.from(document.querySelectorAll('#members-tbody tr'));
  }

  function filteredRows() {
    const name   = document.getElementById('name-search').value.toLowerCase();
    const status = document.querySelector('input[name="status-filter"]:checked').value;
    const sync   = document.querySelector('input[name="sync-filter"]:checked').value;
    return allRows().filter(row =>
      row.dataset.name.includes(name) &&
      (status === '' || row.dataset.active === status) &&
      (sync   === '' || row.dataset.synced === sync)
    );
  }

  function render() {
    const filtered = filteredRows();
    const total    = filtered.length;
    const start    = pageSize === 0 ? 0          : (currentPage - 1) * pageSize;
    const end      = pageSize === 0 ? total       : start + pageSize;
    const pageRows = new Set(filtered.slice(start, end));

    allRows().forEach(row => row.style.display = pageRows.has(row) ? '' : 'none');

    document.getElementById('visible-count').textContent = total;
    document.getElementById('no-results').classList.toggle('d-none', total > 0);

    // Page info
    const info = document.getElementById('page-info');
    if (total === 0 || pageSize === 0) {
      info.textContent = '';
    } else {
      info.textContent = `Showing ${start + 1}–${Math.min(end, total)} of ${total}`;
    }

    renderPagination(total);
    updateBulkBar();
  }

  function renderPagination(total) {
    const container  = document.getElementById('pagination');
    const totalPages = pageSize === 0 ? 1 : Math.ceil(total / pageSize);

    if (totalPages <= 1) { container.innerHTML = ''; return; }

    // Build page range with ellipsis
    const pages = [];
    for (let i = 1; i <= totalPages; i++) {
      if (i === 1 || i === totalPages || (i >= currentPage - 2 && i <= currentPage + 2)) {
        pages.push(i);
      } else if (pages[pages.length - 1] !== '…') {
        pages.push('…');
      }
    }

    let html = '<ul class="pagination pagination-sm mb-0">';
    html += `<li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
      <a class="page-link" href="#" onclick="goToPage(${currentPage - 1});return false;">‹</a></li>`;
    pages.forEach(p => {
      if (p === '…') {
        html += '<li class="page-item disabled"><span class="page-link">…</span></li>';
      } else {
        html += `<li class="page-item ${p === currentPage ? 'active' : ''}">
          <a class="page-link" href="#" onclick="goToPage(${p});return false;">${p}</a></li>`;
      }
    });
    html += `<li class="page-item ${currentPage === totalPages ? 'disabled' : ''}">
      <a class="page-link" href="#" onclick="goToPage(${currentPage + 1});return false;">›</a></li>`;
    html += '</ul>';
    container.innerHTML = html;
  }

  function goToPage(page) {
    const totalPages = pageSize === 0 ? 1 : Math.ceil(filteredRows().length / pageSize);
    if (page < 1 || page > totalPages) return;
    currentPage = page;
    render();
  }

  function onFilterChange() { currentPage = 1; render(); }
  function onPageSizeChange() {
    pageSize    = parseInt(document.getElementById('page-size').value);
    currentPage = 1;
    render();
  }

  function clearFilters() {
    document.getElementById('name-search').value   = '';
    document.getElementById('status-all').checked  = true;
    document.getElementById('sync-all').checked    = true;
    onFilterChange();
  }

  function visibleCheckboxes() {
    return document.querySelectorAll('#members-tbody tr:not([style*="display: none"]) .row-checkbox');
  }

  function updateBulkBar() {
    const checked  = document.querySelectorAll('.row-checkbox:checked');
    const visible  = visibleCheckboxes();
    const bar      = document.getElementById('bulk-bar');
    document.getElementById('bulk-count').textContent = checked.length;
    bar.classList.toggle('d-none', checked.length === 0);
    bar.classList.toggle('d-flex', checked.length > 0);
    const selectAll         = document.getElementById('select-all');
    selectAll.checked       = visible.length > 0 && checked.length === visible.length;
    selectAll.indeterminate = checked.length > 0 && checked.length < visible.length;
  }

  function toggleAll(source) {
    visibleCheckboxes().forEach(cb => cb.checked = source.checked);
    updateBulkBar();
  }

  function clearSelection() {
    document.querySelectorAll('.row-checkbox, #select-all').forEach(cb => cb.checked = false);
    updateBulkBar();
  }

  document.getElementById('bulk-form').addEventListener('submit', function() {
    document.querySelectorAll('.row-checkbox:checked').forEach(function(cb) {
      const input = document.createElement('input');
      input.type  = 'hidden';
      input.name  = 'user_ids[]';
      input.value = cb.dataset.userId;
      document.getElementById('bulk-form').appendChild(input);
    });
  });

  // Initial render
  render();
</script>
