<% content_for :title, "Import Members" %>

<div class="row justify-content-center">
  <div class="col-lg-6">
    <h2 class="mb-4">Import Members</h2>

    <%= form_with url: import_users_path, multipart: true do |f| %>
      <div class="mb-3">
        <%= f.label :file, "CSV File", class: "form-label" %>
        <%= f.file_field :file, class: "form-control", accept: ".csv" %>
      </div>
      <div class="d-flex gap-2">
        <%= f.submit "Import", class: "btn btn-primary" %>
        <%= link_to "Cancel", users_path, class: "btn btn-outline-secondary" %>
      </div>
    <% end %>

    <hr class="my-4">

    <h6>Expected format</h6>
    <p class="text-muted small">Required columns: <code>first_name</code>, <code>last_name</code>, <code>card_number</code><br>
    Optional: <code>site_code</code> (defaults to 105), <code>active</code> (defaults to true)</p>
    <pre class="bg-light p-3 rounded small">first_name,last_name,card_number,site_code,active
Joe,Shiffer,51770,105,true
Jane,Smith,48210,,
Bob,Jones,39104,105,false</pre>
    <p class="text-muted small">Slot numbers are assigned automatically. Members with a card number already in the database are skipped.</p>
  </div>
</div>
