<% content_for :title, "Event Log" %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h2 class="mb-0">Event Log</h2>
</div>

<%# Filter bar %>
<%= form_with url: access_events_path, method: :get, class: "row g-2 align-items-end mb-4" do |f| %>
  <div class="col-auto">
    <%= f.select :event_type,
          [["All types", ""]] + AccessEvent::HUMAN_TYPES.map { |k, v| [v, k] },
          { selected: params[:event_type] },
          class: "form-select" %>
  </div>
  <div class="col-auto">
    <%= f.select :range,
          [["Today", "today"], ["Last 7 days", "week"], ["Last 30 days", "month"], ["All time", "all"]],
          { selected: @range },
          class: "form-select" %>
  </div>
  <div class="col-auto">
    <%= f.submit "Filter", class: "btn btn-outline-secondary" %>
  </div>
  <% if params[:event_type].present? || @range != "week" %>
    <div class="col-auto">
      <%= link_to "Clear", access_events_path, class: "btn btn-link text-muted" %>
    </div>
  <% end %>
<% end %>

<% if @events.any? %>
  <% if @total > 500 %>
    <div class="alert alert-warning py-2">
      Showing the 500 most recent of <%= @total %> matching events. Narrow the date range to see more.
    </div>
  <% end %>

  <table class="table table-hover align-middle">
    <thead class="table-dark">
      <tr>
        <th>Time</th>
        <th>Member</th>
        <th>Event</th>
      </tr>
    </thead>
    <tbody>
      <% @events.each do |event| %>
        <tr>
          <td class="text-nowrap text-muted small">
            <%= event.occurred_at.strftime("%-m/%-d/%Y %-I:%M %p") %>
          </td>
          <td>
            <% if event.user %>
              <%= link_to event.user.full_name, user_path(event.user) %>
            <% else %>
              <span class="text-muted">Unknown</span>
            <% end %>
          </td>
          <td><%= event_type_badge(event) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <p class="text-muted small">
    Showing <%= @events.size %><% if @total > 500 %> of <%= @total %><% end %> events.
  </p>
<% else %>
  <p class="text-muted">No events found for the selected filters.</p>
<% end %>
